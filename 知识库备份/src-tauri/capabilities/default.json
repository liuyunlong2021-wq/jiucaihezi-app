{
  "identifier": "default",
  "description": "Main window capabilities — FS access scoped to app data and OpenCode vault mounts",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "fs:default",
      "allow": [
        { "path": "$APPDATA/**" },
        { "path": "$DOWNLOAD/**" },
        { "path": "$HOME/.jiucaihezi/**" }
      ],
      "deny": [
        { "path": "$HOME/.jiucaihezi/.session" },
        { "path": "$HOME/.jiucaihezi/.session.tmp" }
      ]
    },
    {
      "identifier": "fs:allow-exists",
      "allow": [
        { "path": "$HOME/.jiucaihezi/opencode-runtime/workspace/default/.jiucaihezi-vaults" },
        { "path": "$HOME/.jiucaihezi/opencode-runtime/workspace/default/.jiucaihezi-vaults/**" },
        { "path": "$HOME/.jiucaihezi/opencode-runtime/workspace/default/.jiucaihezi-vaults/current" },
        { "path": "$HOME/.jiucaihezi/opencode-runtime/workspace/default/.jiucaihezi-vaults/current/**" },
        { "path": "$HOME/**/.jiucaihezi-vaults" },
        { "path": "$HOME/**/.jiucaihezi-vaults/**" },
        { "path": "$HOME/**/.jiucaihezi-vaults/current" },
        { "path": "$HOME/**/.jiucaihezi-vaults/current/**" }
      ]
    },
    {
      "identifier": "fs:allow-stat",
      "allow": [
        { "path": "$HOME/.jiucaihezi/opencode-runtime/workspace/default/.jiucaihezi-vaults" },
        { "path": "$HOME/.jiucaihezi/opencode-runtime/workspace/default/.jiucaihezi-vaults/**" },
        { "path": "$HOME/.jiucaihezi/opencode-runtime/workspace/default/.jiucaihezi-vaults/current" },
        { "path": "$HOME/.jiucaihezi/opencode-runtime/workspace/default/.jiucaihezi-vaults/current/**" },
        { "path": "$HOME/**/.jiucaihezi-vaults" },
        { "path": "$HOME/**/.jiucaihezi-vaults/**" },
        { "path": "$HOME/**/.jiucaihezi-vaults/current" },
        { "path": "$HOME/**/.jiucaihezi-vaults/current/**" }
      ]
    },
    "fs:allow-read-dir",
    "fs:allow-read-file",
    "fs:allow-read-text-file",
    "fs:allow-create",
    "fs:allow-write-file",
    {
      "identifier": "fs:allow-write-text-file",
      "allow": [
        { "path": "$HOME/.jiucaihezi/opencode-runtime/workspace/default/.jiucaihezi-vaults" },
        { "path": "$HOME/.jiucaihezi/opencode-runtime/workspace/default/.jiucaihezi-vaults/**" },
        { "path": "$HOME/.jiucaihezi/opencode-runtime/workspace/default/.jiucaihezi-vaults/current" },
        { "path": "$HOME/.jiucaihezi/opencode-runtime/workspace/default/.jiucaihezi-vaults/current/**" },
        { "path": "$HOME/**/.jiucaihezi-vaults" },
        { "path": "$HOME/**/.jiucaihezi-vaults/**" },
        { "path": "$HOME/**/.jiucaihezi-vaults/current" },
        { "path": "$HOME/**/.jiucaihezi-vaults/current/**" }
      ]
    },
    {
      "identifier": "fs:allow-mkdir",
      "allow": [
        { "path": "$HOME/.jiucaihezi/opencode-runtime/workspace/default/.jiucaihezi-vaults" },
        { "path": "$HOME/.jiucaihezi/opencode-runtime/workspace/default/.jiucaihezi-vaults/**" },
        { "path": "$HOME/.jiucaihezi/opencode-runtime/workspace/default/.jiucaihezi-vaults/current" },
        { "path": "$HOME/.jiucaihezi/opencode-runtime/workspace/default/.jiucaihezi-vaults/current/**" },
        { "path": "$HOME/**/.jiucaihezi-vaults" },
        { "path": "$HOME/**/.jiucaihezi-vaults/**" },
        { "path": "$HOME/**/.jiucaihezi-vaults/current" },
        { "path": "$HOME/**/.jiucaihezi-vaults/current/**" }
      ]
    },
    {
      "identifier": "fs:allow-remove",
      "allow": [
        { "path": "$HOME/.jiucaihezi/opencode-runtime/workspace/default/.jiucaihezi-vaults" },
        { "path": "$HOME/.jiucaihezi/opencode-runtime/workspace/default/.jiucaihezi-vaults/**" },
        { "path": "$HOME/.jiucaihezi/opencode-runtime/workspace/default/.jiucaihezi-vaults/current" },
        { "path": "$HOME/.jiucaihezi/opencode-runtime/workspace/default/.jiucaihezi-vaults/current/**" },
        { "path": "$HOME/**/.jiucaihezi-vaults" },
        { "path": "$HOME/**/.jiucaihezi-vaults/**" },
        { "path": "$HOME/**/.jiucaihezi-vaults/current" },
        { "path": "$HOME/**/.jiucaihezi-vaults/current/**" }
      ]
    },
    "fs:allow-rename",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-confirm",
    "dialog:allow-ask",
    "shell:default",
    "shell:allow-open",
    "process:default",
    "notification:default",
    "sql:default",
    "sql:allow-load",
    "sql:allow-execute",
    "sql:allow-select"
  ]
}
