# Attachment Processor
# See docker-compose.yml and app/settings.py for all config options.

# Server
HOST=0.0.0.0
PORT=8091
LOG_LEVEL=info

# Limits
MAX_UPLOAD_MB=20
MAX_PDF_PAGES=20
SYNC_PARSE_TIMEOUT_S=120

# 8090 Office/Graphify（宿主机直连用 127.0.0.1, Docker 内用 host.docker.internal）
OFFICE_GRAPHIFY_BASE_URL=http://127.0.0.1:8090

# PaddleOCR: 本地安装时设为 1，远程 serving 时设为 0
PADDLE_USE_LOCAL=1
# PADDLEX_SERVING_URL=http://127.0.0.1:8080

# Auth: 8091 只监听 127.0.0.1，鉴权由 Nginx 代理层完成。
# 无需设置 AUTH_SHARED_SECRET。
