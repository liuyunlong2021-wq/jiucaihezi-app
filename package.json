{
  "name": "jiucaihezi-app",
  "private": true,
  "version": "0.1.7",
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "vite",
    "typecheck": "vue-tsc -b",
    "build": "pnpm run test:focused && vue-tsc -b && vite build && node scripts/prune-web-dist.mjs && pnpm run audit:web-dist",
    "build:desktop": "pnpm run test:focused && vue-tsc -b && vite build && node scripts/prune-desktop-dist.mjs && pnpm run audit:desktop-dist",
    "audit:desktop-dist": "node scripts/audit-desktop-dist.mjs",
    "audit:web-dist": "node scripts/audit-web-dist.mjs",
    "audit:web-direct-boundary": "node scripts/audit-web-direct-boundary.mjs",
    "opencode:update": "node scripts/update-opencode-runtime.mjs",
    "preview": "vite preview",
    "test:focused:build": "node scripts/run-focused-tests.mjs build",
    "test:focused:run": "node scripts/run-focused-tests.mjs run",
    "test:conversation:build": "esbuild src/runtime/conversationContext/__tests__/engine.test.ts src/runtime/conversationContext/__tests__/longFormStress.test.ts src/runtime/conversationContext/__tests__/continuation.test.ts src/runtime/conversationContext/__tests__/jobWorker.test.ts src/runtime/conversationContext/__tests__/rebuildIndex.test.ts src/runtime/conversationContext/__tests__/storage.test.ts --bundle --platform=node --format=esm --alias:@=./src --outbase=src --outdir=/private/tmp/jc-conversation-tests",
    "test:conversation:run": "node --test /private/tmp/jc-conversation-tests/runtime/conversationContext/__tests__/engine.test.js /private/tmp/jc-conversation-tests/runtime/conversationContext/__tests__/longFormStress.test.js /private/tmp/jc-conversation-tests/runtime/conversationContext/__tests__/continuation.test.js /private/tmp/jc-conversation-tests/runtime/conversationContext/__tests__/jobWorker.test.js /private/tmp/jc-conversation-tests/runtime/conversationContext/__tests__/rebuildIndex.test.js /private/tmp/jc-conversation-tests/runtime/conversationContext/__tests__/storage.test.js",
    "test:conversation": "pnpm run test:conversation:build && pnpm run test:conversation:run",
    "test:tauri": "cargo test --manifest-path src-tauri/Cargo.toml",
    "test:focused": "pnpm run test:focused:build && pnpm run test:focused:run && pnpm run test:tauri",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build && node scripts/fix-macos-app.mjs",
    "tauri:fix-macos-app": "node scripts/fix-macos-app.mjs",
    "tauri:dmg:official": "node scripts/create-official-dmg.mjs",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt --check",
    "format:fix": "oxfmt",
    "check": "pnpm run format && pnpm run lint && pnpm exec vue-tsc -b",
    "check:fix": "pnpm run format:fix && pnpm run lint:fix && pnpm exec vue-tsc -b"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opencode-ai/sdk": "1.17.6",
    "@tauri-apps/api": "^2.5.0",
    "@tauri-apps/plugin-deep-link": "^2.4.9",
    "@tauri-apps/plugin-dialog": "^2.2.0",
    "@tauri-apps/plugin-fs": "^2.3.0",
    "@tauri-apps/plugin-notification": "^2.2.0",
    "@tauri-apps/plugin-process": "^2.2.0",
    "@tauri-apps/plugin-shell": "^2.2.0",
    "@tauri-apps/plugin-sql": "^2.4.0",
    "@tiptap/core": "^3.23.4",
    "@tiptap/extension-bubble-menu": "^3.24.0",
    "@tiptap/extension-character-count": "^3.23.2",
    "@tiptap/extension-code-block-lowlight": "^3.24.0",
    "@tiptap/extension-color": "^3.23.4",
    "@tiptap/extension-details": "^3.24.0",
    "@tiptap/extension-drag-handle": "^3.24.0",
    "@tiptap/extension-drag-handle-vue-3": "^3.24.0",
    "@tiptap/extension-file-handler": "^3.24.0",
    "@tiptap/extension-floating-menu": "^3.24.0",
    "@tiptap/extension-highlight": "^3.23.4",
    "@tiptap/extension-image": "^3.23.2",
    "@tiptap/extension-link": "^3.23.2",
    "@tiptap/extension-mention": "^3.23.4",
    "@tiptap/extension-node-range": "^3.24.0",
    "@tiptap/extension-placeholder": "^3.23.2",
    "@tiptap/extension-table-of-contents": "^3.24.0",
    "@tiptap/extension-task-item": "^3.23.4",
    "@tiptap/extension-task-list": "^3.23.4",
    "@tiptap/extension-text-align": "^3.24.0",
    "@tiptap/extension-text-style": "^3.23.4",
    "@tiptap/extension-typography": "^3.23.4",
    "@tiptap/extension-underline": "^3.23.2",
    "@tiptap/extension-unique-id": "^3.24.0",
    "@tiptap/markdown": "^3.24.0",
    "@tiptap/pm": "^3.23.4",
    "@tiptap/starter-kit": "^3.23.2",
    "@tiptap/static-renderer": "^3.24.0",
    "@tiptap/suggestion": "^3.23.4",
    "@tiptap/vue-3": "^3.23.2",
    "@vue-flow/background": "^1.3.2",
    "@vue-flow/controls": "^1.1.3",
    "@vue-flow/core": "^1.48.2",
    "@vue-flow/minimap": "^1.5.4",
    "dompurify": "^3.4.2",
    "highlight.js": "^11.11.1",
    "html-to-image": "^1.11.13",
    "katex": "^0.17.0",
    "lowlight": "^3.3.0",
    "marked": "^18.0.3",
    "mermaid": "^11.15.0",
    "pinia": "^3.0.4",
    "tokenx": "^1.3.0",
    "vue": "^3.5.32",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.5.0",
    "@types/katex": "^0.16.8",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
    "esbuild": "^0.28.0",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.10",
    "vue-tsc": "^3.2.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
