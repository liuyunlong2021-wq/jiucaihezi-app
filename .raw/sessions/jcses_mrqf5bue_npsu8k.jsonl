"grid-pattern\" width=\"80\" height=\"80\" patternUnits=\"userSpaceOnUse\">\n60:             <path d=\"M 80 0 L 0 0 0 80\" fill=\"none\" stroke=\"#4A5D23\" stroke-width=\"0.5\" opacity=\"0.3\"/>\n61:           </pattern>\n62:         </defs>\n63:         <rect width=\"1920\" height=\"1080\" fill=\"url(#grid-pattern)\"/>\n64:       </svg>\n65: \n66:       <div id=\"bg-glow\" class=\"clip\" data-start=\"0\" data-duration=\"30\" data-track-index=\"2\"></div>\n67: \n68:       <div id=\"scan-line\" class=\"clip\" data-start=\"0\" data-duration=\"4\" data-track-index=\"3\" style=\"top:0;left:0;width:1920px;height:2px;\"></div>\n69: \n70:       <div id=\"particle-1\" class=\"particle clip\" data-start=\"0\" data-duration=\"30\" data-track-index=\"4\" style=\"left:200px;top:300px;\"></div>\n71:       <div id=\"particle-2\" class=\"particle clip\" data-start=\"0\" data-duration=\"30\" data-track-index=\"5\" style=\"left:700px;top:150px;\"></div>\n72:       <div id=\"particle-3\" class=\"particle clip\" data-start=\"0\" data-duration=\"30\" data-track-index=\"6\" style=\"left:1400px;top:200px;\"></div>\n73:       <div id=\"particle-4\" class=\"particle clip\" data-start=\"0\" data-duration=\"30\" data-track-index=\"7\" style=\"left:300px;top:800px;\"></div>\n74:       <div id=\"particle-5\" class=\"particle clip\" data-start=\"0\" data-duration=\"30\" data-track-index=\"8\" style=\"left:1600px;top:700px;\"></div>\n75:       <div id=\"particle-6\" class=\"particle clip\" data-start=\"0\" data-duration=\"30\" data-track-index=\"9\" style=\"left:1000px;top:900px;\"></div>\n76:       <div id=\"particle-7\" class=\"particle clip\" data-start=\"0\" data-duration=\"30\" data-track-index=\"10\" style=\"left:500px;top:500px;\"></div>\n77:       <div id=\"particle-8\" class=\"particle clip\" data-start=\"0\" data-duration=\"30\" data-track-index=\"11\" style=\"left:1200px;top:400px;\"></div>\n78: \n79:       <div id=\"corner-tl\" class=\"corner-bracket tl clip\" data-start=\"0\" data-d