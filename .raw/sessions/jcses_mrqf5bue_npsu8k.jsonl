geDegraded)\n70: })\n71: \n72: function isPanelAvailable(mode: string) {\n73:   return !isWebRuntime.value || !WEB_UNSUPPORTED_PANELS.has(mode)\n74: }\n75: \n76: // ─── 移动端适配 ───\n77: const isMobile = ref(false)\n78: const mobilePanel = ref<'chat' | 'history' | 'creation' | 'settings'>('chat')\n79: \n80: function checkMobile() {\n81:   isMobile.value = window.innerWidth <= 768\n82: }\n83: \n84: // ─── Col 5 当前面板 ───\n85: const workspaceMode = ref<'chat' | 'canvas'>('chat') // 画布已移除，固定 chat\n86: const rightPanel = ref<string>('settings')\n87: const showHelpGuide = ref(false)\n88: const helpGuideHtml = ref('')\n89: const helpGuideLoading = ref(false)\n90: \n91: async function openHelpGuide() {\n92:   if (helpGuideHtml.value) { showHelpGuide.value = true; return }\n93:   helpGuideLoading.value = true\n94:   try {\n95:     const resp = await fetch('/help/guide.md')\n96:     const md = await resp.text()\n97:     // 修正图片路径：相对路径 → 绝对路径\n98:     const fixed = md.replace(/\\(images\\//g, '(/help/images/')\n99:     helpGuideHtml.value = await marked.parse(fixed)\n100:     showHelpGuide.value = true\n101:   } catch {\n102:     helpGuideHtml.value = '<p>帮助文档加载失败，请稍后重试。</p>'\n103:     showHelpGuide.value = true\n104:   } finally {\n105:     helpGuideLoading.value = false\n106:   }\n107: }\n108: \n109: // 监听全局面板切换事件（如 MessageBubble 导入编辑区）\n110: \n111: // 监听全局面板切换事件（如 MessageBubble 导入编辑区）\n112: const offSwitchPanel = onEvent('switch-panel', (panel: unknown) => {\n113:   if (typeof panel === 'string') {\n114:     if (panel === 'chat') {\n115:       if (isMobile.value) mobilePanel.value = 'chat'\n116:       else rightPanel.value = ''\n117:       workspaceMode.value = 'chat'\n118:       return\n119:     }\n120:     openMemberPanel(panel)\n121:   }\n122: })\n123: \n124: const offShowHistoryList = onEvent('show-history-list', () => {\n125:   isFileTreeCollapsed.value = false\n126: })\n127: \n128: const offToggleFileTree = onEvent('toggle-file-tree', () => {\n129:   isFileTreeCollapsed.