ts || '{}') } catch { /* keep raw arguments for malformed calls */ }\n108:           await record('tool_call', { tool: call.function.name, arguments: args })\n109:           if (call.function.name !== 'skill') {\n110:             const approved = await input.confirmTool?.(call)\n111:             if (approved === false) {\n112:               result = { content: '用户拒绝了本次工具操作，未执行。请换一种方法继续。', status: 'cancelled' }\n113:               status = 'cancelled'\n114:               input.onToolResult?.(call, result.content, status)\n115:               await record('tool_result', { tool: call.function.name, status, result: result.content })\n116:               return result\n117:             }\n118:           }\n119:           result = await projectTools(call)\n120:           status = result.status || 'succeeded'\n121:         } catch (error) {\n122:           if (activeController.signal.aborted) {\n123:             result = { content: '工具执行已取消。', status: 'cancelled' }\n124:             status = 'cancelled'\n125:             input.onToolResult?.(call, result.content, status)\n126:             await record('tool_result', { tool: call.function.name, status, result: result.content })\n127:             throw new DOMException('Aborted', 'AbortError')\n128:           }\n129:           result = { content: `Tool error: ${error instanceof Error ? error.message : String(error)}` }\n130:           status = 'failed'\n131:         }\n132:         input.onToolResult?.(call, result.content, status)\n133:         await record('tool_result', { tool: call.function.name, status, result: result.content })\n134:         return result\n135:       }\n136:       let roundText = ''\n137:       const result = await runDirectChatCompletion({\n138:         messages,\n139:         tools: CREATIVE_PROJECT_TOOL_DEFINITIONS,\n140:         executeTool,\n141:         signal: activeController.signal,\n142:         onText: text => {\n143:           roundText = text\n144:           input.onText(text)\n145:         