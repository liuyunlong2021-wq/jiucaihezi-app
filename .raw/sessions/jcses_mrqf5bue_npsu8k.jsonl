tory, generation))\n89:   return projectSwitch\n90: }\n91: \n92: onMounted(async () => {\n93:   try {\n94:     showSetupWizard.value = await shouldShowSetupWizard()\n95:   } catch { /* ignore */ }\n96:   if (disposed) return\n97: \n98:   // P1: 新版本检测\n99:   checkNewVersion().catch(() => {})\n100:   void queueOpenCodeProjectSwitch(projectStore.projectDir.value).catch(error => {\n101:     console.error('[OpenCode sync] 启动失败', error)\n102:   })\n103:   stopProjectWatch = watch([projectStore.projectDir, () => chatModeStore.mode], ([directory]) => {\n104:     void queueOpenCodeProjectSwitch(directory).catch(error => {\n105:       console.error('[OpenCode sync] 切换目录失败', error)\n106:     })\n107:   })\n108: })\n109: \n110: onBeforeUnmount(() => {\n111:   disposed = true\n112:   projectSwitchGeneration++\n113:   stopProjectWatch?.()\n114:   openCodeSyncStore.disconnect()\n115: })\n116: \n117: async function checkNewVersion() {\n118:   try {\n119:     const resp = await fetch(\n120:       'https://api.github.com/repos/liuyunlong2021-wq/jiucaihezi-app/releases/latest',\n121:       { signal: AbortSignal.timeout(5000) }\n122:     )\n123:     if (!resp.ok) return\n124:     const release = await resp.json()\n125:     const latestVer = (release.tag_name || '').replace(/^v/, '')\n126:     const currentVer = ((window as any).__JC_APP_BUILD_ID__ || '')\n127:       .match(/[\\d.]+/)?.[0] || '0'\n128: \n129:     if (latestVer > currentVer) {\n130:       const ok = window.confirm(\n131:         `韭菜盒子 ${release.tag_name} 已发布！\\n\\n` +\n132:         `当前版本：v${currentVer}\\n` +\n133:         `最新版本：${release.tag_name}\\n\\n` +\n134:         `点击「确定」前往下载页。`\n135:       )\n136:       if (ok) {\n137:         window.open('https://api.jiucaihezi.studio/download/', '_blank')\n138:       }\n139:     }\n140:   } catch { /* 静默失败 */ }\n141: }\n142: </script>\n143: \n144: <template>\n145:   <WorkspaceLayout />\n146:   <GlobalSearch />\n147:   <LocalCapabilitySetup\n148:     v-if=\"showSetupWizard\"\n149:     mode=\"modal\"\n150:     @close=\"showSetupWizard = false\"\n151:   />\n152: </template>\n153: "}}
