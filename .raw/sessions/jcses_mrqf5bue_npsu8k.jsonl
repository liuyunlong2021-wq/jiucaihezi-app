61: \n62: export const useMcpStore = defineStore('mcp', () => {\n63:   const servers = ref<McpServerConfig[]>([])\n64:   const tools = ref<Map<string, McpToolSchema[]>>(new Map())\n65:   const loaded = ref(false)\n66: \n67:   // Lazy init\n68:   async function ensureLoaded() {\n69:     if (loaded.value) return\n70:     servers.value = await loadServers()\n71:     loaded.value = true\n72:   }\n73:   ensureLoaded()\n74: \n75:   // ─── Computed ──────────────────────────────────────\n76: \n77:   const enabledServers = computed(() =>\n78:     servers.value.filter(s => s.enabled)\n79:   )\n80: \n81:   const connectedServers = computed(() =>\n82:     servers.value.filter(s => s.enabled && s.status === 'connected')\n83:   )\n84: \n85:   const allMcpTools = computed((): McpToolSchema[] => {\n86:     const result: McpToolSchema[] = []\n87:     for (const s of connectedServers.value) {\n88:       const serverTools = tools.value.get(s.id) || []\n89:       result.push(...serverTools)\n90:     }\n91:     return result\n92:   })\n93: \n94:   // ─── Actions ───────────────────────────────────────\n95: \n96:   function addServer(config: Omit<McpServerConfig, 'status' | 'error' | 'enabled'>) {\n97:     const server: McpServerConfig = {\n98:       ...config,\n99:       enabled: false,\n100:       status: 'disconnected',\n101:     }\n102:     servers.value.push(server)\n103:     persist()\n104:     return server\n105:   }\n106: \n107:   function removeServer(id: string) {\n108:     servers.value = servers.value.filter(s => s.id !== id)\n109:     tools.value.delete(id)\n110:     persist()\n111:   }\n112: \n113:   function updateServer(id: string, patch: Partial<McpServerConfig>) {\n114:     const server = servers.value.find(s => s.id === id)\n115:     if (!server) return\n116:     Object.assign(server, patch)\n117:     persist()\n118:   }\n119: \n120:   function setServerStatus(id: string, status: McpServerConfig['status'], error?: string) {\n121:     const server = servers.value.find(s => s.id === id)\n122:     if (!server) return\n123:     server.status = status\n124:     server.error = error\n125:     if (status === 'disconnected') {\n126:       tools.value.delete(id)\n127:     }\n128:     persist()\n129:   }\n130: \n131:   function setServerTools(id: string, serverTools: McpToolSchema[]) {\n132:     tools.value.set(id, serverTools)\n133:   }\n134: \n135:   function isServerEnabled(id: string): boolean {\n136:     return Boolean(servers.value.find(s => s.id === id)?.enabled)\n137:   }\n138: \n139:   function isServerConnected(id: string): boolean {\n140:     const server = servers.value.find(s => s.id === id)\n141:     return Boolean(server?.enabled && server.status === 'connected')\n142:   }\n143: \n144:   function getMcpToolByName(toolName: string): McpToolSchema | null {\n145:     return allMcpTools.value.find(tool => tool.name === toolName) || null\n146:   }\n147: \n148:   function toggleServer(id: string) {\n149:     const server = servers.value.find(s => s.id === id)\n150:     if (!server) return\n151:     server.enabled = !server.enabled\n152:     if (!server.enabled) {\n153:       server.status = 'disconnected'\n154:       tools.value.delete(id)\n155:     }\n156:     persist()\n157:   }\n158: \n159:   function persist() {\n160:     saveServers(servers.value.map(s => ({\n161:       ...s,\n162:       status: 'disconnected' as const, // never persist connection state\n163:       error: undefined,\n164:     })))\n165:   }\n166: \n167:   return {\n168:     servers,\n169:     tools,\n170:     enabledServers,\n171:     allMcpTools,\n172:     connectedServers,\n173:     addServer,\n174:     removeServer,\n175:     updateServer,\n176:     setServerStatus,\n177:     setServerTools,\n178:     isServerEnabled,\n179:     isServerConnected,\n180:     getMcpToolByName,\n181:     toggleServer,\n182:   }\n183: })\n184: "}}
