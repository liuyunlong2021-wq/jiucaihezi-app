{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "voice-bound-shot-video/result.schema.json",
  "title": "Voice Bound Shot Video Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "shot_id",
    "render_route",
    "status",
    "input",
    "runtime"
  ],
  "properties": {
    "shot_id": {
      "type": "string",
      "minLength": 1
    },
    "render_route": {
      "const": "voice_bound_shot_video"
    },
    "status": {
      "type": "string",
      "enum": ["success", "failed", "unsupported", "queued", "running"]
    },
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "first_frame",
        "voice_audio",
        "dialogue_text",
        "width",
        "height"
      ],
      "properties": {
        "first_frame": {
          "type": "string"
        },
        "voice_audio": {
          "type": "string"
        },
        "dialogue_text": {
          "type": "string"
        },
        "motion_tag": {
          "type": "string"
        },
        "motion_prompt_cn": {
          "type": "string"
        },
        "width": {
          "type": "integer",
          "minimum": 1
        },
        "height": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "video": {
          "type": "string"
        },
        "response_json": {
          "type": "string"
        }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider", "workflow_type", "app_url"],
      "properties": {
        "provider": {
          "const": "runninghub"
        },
        "workflow_type": {
          "const": "voice_bound_video_app"
        },
        "app_url": {
          "type": "string",
          "format": "uri"
        },
        "task_id": {
          "type": "string"
        }
      }
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string"
        },
        "message": {
          "type": "string"
        }
      }
    }
  }
}
