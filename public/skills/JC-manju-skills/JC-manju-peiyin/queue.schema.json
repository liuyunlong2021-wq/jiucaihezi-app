{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "voice-bound-shot-video/queue.schema.json",
  "title": "Voice Bound Shot Video Queue",
  "type": "object",
  "additionalProperties": false,
  "required": ["queue_id", "items"],
  "properties": {
    "queue_id": {
      "type": "string",
      "minLength": 1
    },
    "project_id": {
      "type": "string"
    },
    "created_at": {
      "type": "string"
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["shot_id", "request_path"],
        "properties": {
          "shot_id": {
            "type": "string",
            "minLength": 1
          },
          "request_path": {
            "type": "string",
            "minLength": 1
          },
          "priority": {
            "type": "integer"
          },
          "enabled": {
            "type": "boolean",
            "default": true
          },
          "notes": {
            "type": "string"
          }
        }
      }
    }
  }
}
