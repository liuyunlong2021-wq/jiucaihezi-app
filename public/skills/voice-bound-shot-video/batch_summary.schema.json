{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "voice-bound-shot-video/batch_summary.schema.json",
  "title": "Voice Bound Shot Video Batch Summary",
  "type": "object",
  "additionalProperties": false,
  "required": ["queue_id", "status", "items"],
  "properties": {
    "queue_id": {
      "type": "string",
      "minLength": 1
    },
    "project_id": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["success", "partial", "failed"]
    },
    "stats": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "total": {
          "type": "integer",
          "minimum": 0
        },
        "succeeded": {
          "type": "integer",
          "minimum": 0
        },
        "failed": {
          "type": "integer",
          "minimum": 0
        },
        "skipped": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["shot_id", "request_path", "status"],
        "properties": {
          "shot_id": {
            "type": "string"
          },
          "request_path": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["success", "failed", "skipped"]
          },
          "result_path": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    }
  }
}
