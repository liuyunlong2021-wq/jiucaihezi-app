{
  "identifier": "default",
  "description": "Main window capabilities — FS access scoped to app data",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    {
      "identifier": "fs:default",
      "allow": [
        { "path": "$APPDATA/**" },
        { "path": "$DOWNLOAD/**" },
        { "path": "$HOME/.jiucaihezi/**" },
        { "path": "$HOME/韭菜盒子/**" },
        { "path": "$HOME/.agents/**" },
        { "path": "$HOME/.skillsmanage/**" }
      ],
      "deny": [
        { "path": "$HOME/.jiucaihezi/.session" },
        { "path": "$HOME/.jiucaihezi/.session.tmp" }
      ]
    },
    "fs:allow-read-dir",
    "fs:allow-read-file",
    "fs:allow-read-text-file",
    "fs:allow-exists",
    "fs:allow-create",
    "fs:allow-write-file",
    "fs:allow-write-text-file",
    "fs:allow-mkdir",
    "fs:allow-remove",
    "fs:allow-rename",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-confirm",
    "dialog:allow-ask",
    "shell:default",
    "shell:allow-open",
    "deep-link:default",
    "deep-link:allow-get-current",
    "process:default",
    "notification:default",
    "sql:default",
    "sql:allow-load",
    "sql:allow-execute",
    "sql:allow-select",
    "updater:default",
    "updater:allow-check",
    "updater:allow-download-and-install"
  ]
}
