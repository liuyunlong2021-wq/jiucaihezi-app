{
  "$schema": "https://raw.githubusercontent.com/nicoulaj/schemastore/master/src/schemas/json/tauri-v2.json",
  "productName": "韭菜盒子",
  "version": "1.0.15",
  "identifier": "com.jiucaihezi.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build:desktop:quick"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "url": "index.html",
        "title": "韭菜盒子",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "create": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:* http://localhost:* https://localhost:* ws://127.0.0.1:* ws://localhost:* https://*.jiucaihezi.studio https://api.github.com https://*.openai.com https://*.anthropic.com https://*.googleapis.com https://*.xai.dev https://*.myqcloud.com https://*.aiproxy.vip https://aiproxy.vip https://challenges.cloudflare.com; img-src 'self' data: blob: https: asset: http://asset.localhost; media-src 'self' data: blob: https: asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; script-src 'self'; font-src 'self' data:",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/output/**",
          "$APPDATA/data/media/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/yt-dlp",
      "binaries/ffmpeg",
      "binaries/ffprobe",
      "binaries/whisper-cli",
      "binaries/opencode"
    ],
    "icon": [
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "signingIdentity": "Developer ID Application: yunlong liu (RXD4L9387J)"
    },
    "windows": {
      "wix": null,
      "nsis": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "jiucaihezi"
        ]
      }
    },
    "shell": {
      "open": true
    }
  }
}
