# rh-adapter Configuration
# Copy to .env and fill in your values

# Required: RunningHub API Key
RUNNINGHUB_API_KEY=

# Optional: server settings
HOST=0.0.0.0
PORT=8789
LOG_LEVEL=info

# Optional: custom RunningHub AI App models.
# JSON array or object. Add the same model id to the NewAPI channel for billing.
RH_CUSTOM_AI_APPS=
# RH_CUSTOM_AI_APPS=[{"id":"rh-custom-demo","label":"自建视频Demo","output_type":"video","webapp_id":"123456789"}]

# Optional: AI App whitelist — comma-separated webapp IDs
# Empty = allow all; non-empty = only allow listed IDs
RH_AI_APP_WHITELIST=
# RH_AI_APP_WHITELIST=2028055408421642241,2036019863617015809,2029950473750454274,2046193597401276417,2035739697670000642

# Optional: polling settings
MAX_POLL_SECONDS=600
POLL_INTERVAL_IMAGE=5
POLL_INTERVAL_VIDEO=10
